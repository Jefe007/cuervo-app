# ─── PostgreSQL (Neon.tech) ───────────────────────────────────────────────────
# Copia el "Connection string" desde Neon Dashboard > tu proyecto > Connect
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# El archivo de credenciales se carga directamente desde el sistema de archivos.
# Coloca el JSON descargado de Firebase Console en: backend/firebase-service-account.json
# NUNCA subas ese archivo a git (ya está en .gitignore).

# ─── Servidor ─────────────────────────────────────────────────────────────────
# Railway inyecta PORT automáticamente; no lo cambies en producción
PORT=3000

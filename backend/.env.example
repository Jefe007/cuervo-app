# ─── PostgreSQL (Neon.tech) ───────────────────────────────────────────────────
# Copia el "Connection string" desde Neon Dashboard > tu proyecto > Connect
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# En Railway (producción): pega el JSON del service account minificado en una sola línea.
# En local: déjalo vacío — el servidor carga firebase-service-account.json como fallback.
# NUNCA subas firebase-service-account.json a git (ya está en .gitignore).
FIREBASE_SERVICE_ACCOUNT=

# ─── Servidor ─────────────────────────────────────────────────────────────────
# Railway inyecta PORT automáticamente; no lo cambies en producción
PORT=3000
